{
  "name": "specifian",
  "version": "0.1.0-beta.0",
  "description": "Spec-as-code documentation tool: render and edit local MDX specs with front-matter as structured design data",
  "keywords": [
    "documentation",
    "mdx",
    "specification",
    "design-docs",
    "frontmatter",
    "wiki",
    "scaffolding",
    "mcp"
  ],
  "author": "Kengo Asamizu",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rabitarochan/specifian.git"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "specifian": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch --import tsx src/cli/index.ts serve --dir examples/.specs --port 4399",
    "dev:client": "vite",
    "build": "tsup && vite build",
    "typecheck": "tsc --noEmit",
    "specifian": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js serve --dir examples/.specs",
    "prepublishOnly": "npm run typecheck && npm run build",
    "publish:beta": "npm version prerelease --preid=beta && npm publish --tag beta"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scaffdog/engine": "^4.1.0",
    "ajv": "^8.17.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.25.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@codemirror/lang-markdown": "^6.3.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@mdx-js/react": "^3.1.0",
    "@types/d3-force": "^3.0.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@uiw/react-codemirror": "^4.23.6",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.0",
    "d3-force": "^3.0.0",
    "mermaid": "^11.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "sucrase": "^3.35.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unist-util-visit": "^5.0.0",
    "vite": "^8.0.16",
    "yaml": "^2.6.1"
  }
}
