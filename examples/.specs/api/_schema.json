{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "API Definition Schema",
  "description": "Schema for defining API endpoint specifications",
  "type": "object",
  "required": ["title", "endpoint"],
  "properties": {
    "title": {
      "type": "string",
      "title": "Title",
      "description": "Title of the API"
    },
    "description": {
      "type": "string",
      "title": "Description",
      "description": "Description of the API"
    },
    "endpoint": {
      "type": "object",
      "title": "Endpoint",
      "description": "API endpoint definition",
      "required": ["method", "path"],
      "properties": {
        "method": {
          "type": "string",
          "title": "Method",
          "description": "HTTP method",
          "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"]
        },
        "path": {
          "type": "string",
          "title": "Path",
          "description": "Endpoint path"
        },
        "description": {
          "type": "string",
          "title": "Description",
          "description": "Description of the endpoint"
        },
        "params": {
          "type": "array",
          "title": "Parameters",
          "description": "Query parameters or request body parameters",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "title": "Parameter Name",
                "description": "Parameter name"
              },
              "type": {
                "type": "string",
                "title": "Type",
                "description": "Parameter type (e.g. string, integer, boolean)"
              },
              "required": {
                "type": "boolean",
                "title": "Required",
                "description": "Whether the parameter is required"
              },
              "description": {
                "type": "string",
                "title": "Description",
                "description": "Description of the parameter"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
