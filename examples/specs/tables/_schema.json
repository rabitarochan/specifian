{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "テーブル定義スキーマ",
  "description": "データベーステーブルの仕様を定義するスキーマ",
  "type": "object",
  "required": ["title", "table"],
  "properties": {
    "title": {
      "type": "string",
      "description": "テーブルのタイトル"
    },
    "description": {
      "type": "string",
      "description": "テーブルの説明"
    },
    "table": {
      "type": "object",
      "description": "テーブル定義",
      "required": ["name", "columns"],
      "properties": {
        "name": {
          "type": "string",
          "description": "テーブル名（データベース側の実際の名前）"
        },
        "description": {
          "type": "string",
          "description": "テーブルの詳細説明"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "description": "カラムリスト",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "description": "カラム名"
              },
              "type": {
                "type": "string",
                "description": "データ型（bigint、varchar など）"
              },
              "nullable": {
                "type": "boolean",
                "description": "NULL を許可するか"
              },
              "primaryKey": {
                "type": "boolean",
                "description": "主キーであるか"
              },
              "default": {
                "type": "string",
                "description": "デフォルト値"
              },
              "description": {
                "type": "string",
                "description": "カラムの説明"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
