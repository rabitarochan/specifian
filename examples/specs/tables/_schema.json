{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Table Definition Schema",
  "description": "Schema for defining database table specifications",
  "type": "object",
  "required": ["title", "table"],
  "properties": {
    "title": {
      "type": "string",
      "title": "Title",
      "description": "Title of the table"
    },
    "description": {
      "type": "string",
      "title": "Description",
      "description": "Description of the table"
    },
    "table": {
      "type": "object",
      "title": "Table Definition",
      "description": "Table definition",
      "required": ["name", "columns"],
      "properties": {
        "name": {
          "type": "string",
          "title": "Table Name",
          "description": "Actual table name in the database"
        },
        "description": {
          "type": "string",
          "title": "Table Description",
          "description": "Detailed description of the table"
        },
        "columns": {
          "type": "array",
          "title": "Columns",
          "minItems": 1,
          "description": "List of columns",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "title": "Column Name",
                "description": "Column name"
              },
              "type": {
                "type": "string",
                "title": "Type",
                "description": "Data type (e.g. bigint, varchar)"
              },
              "nullable": {
                "type": "boolean",
                "title": "Nullable",
                "description": "Whether NULL is allowed"
              },
              "primaryKey": {
                "type": "boolean",
                "title": "Primary Key",
                "description": "Whether this column is the primary key"
              },
              "default": {
                "type": "string",
                "title": "Default Value",
                "description": "Default value"
              },
              "description": {
                "type": "string",
                "title": "Description",
                "description": "Description of the column"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
